# **CRITICAL FIX: TTL Command Deadlock Issue**
# 
# Problem: TTL command hanging due to race conditions and missing locks
# Root Cause: Methods accessing data_ without proper synchronization

--- meteor_commercial_lru_ttl.cpp.original
+++ meteor_commercial_lru_ttl.cpp.fixed

@@ -1576,12 +1576,21 @@ namespace storage {
         bool lazy_expire_if_needed(const std::string& key) {
